# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Password required to unlock the admin dashboard console
ADMIN_PASSWORD="my-secure-admin-password"

# GITHUB_TOKEN: GitHub Personal Access Token (PAT) with write permissions to the repository
GITHUB_TOKEN="ghp_yourpersonalaccesstokenhere"

# GITHUB_OWNER: The username or organization owner of the GitHub repository
GITHUB_OWNER="your-github-username-or-org"

# GITHUB_REPO: The name of the GitHub repository storing the drama genres JSON
GITHUB_REPO="your-genres-repo-name"

# GITHUB_BRANCH: The branch to fetch and commit changes to (e.g. main)
GITHUB_BRANCH="main"

# GITHUB_FILE_PATH: The path to the genres JSON file in the repository (e.g. genres.json)
GITHUB_FILE_PATH="genres.json"

# GITHUB_HERO_FILE_PATH: The path to the hero banner config JSON file in the repository (e.g. hero_config.json)
GITHUB_HERO_FILE_PATH="hero_config.json"

# TMDB_API_KEY: Optional. Your TheMovieDatabase (TMDB) API key or read-access token.
# Used for pulling live details and names of shows inside the Hero Banner Pager.
# If omitted, the server will utilize Gemini AI to synthesize show metadata in real-time.
TMDB_API_KEY=""
